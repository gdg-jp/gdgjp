{
  "name": "@gdgjp/wiki",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "react-router build",
    "dev": "react-router dev",
    "start": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "wrangler types && react-router typegen && tsc --noEmit",
    "cf-typegen": "wrangler types",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:golden": "vitest run tests/golden",
    "test:golden:update": "vitest run tests/golden -u",
    "test:e2e": "playwright test --pass-with-no-tests",
    "migrate:local": "wrangler d1 migrations apply gdgjp-wiki-db --local && pnpm schema:dump",
    "migrate:remote": "wrangler d1 migrations apply gdgjp-wiki-db --remote && pnpm schema:dump",
    "schema:dump": "bash ../scripts/dump-schema.sh"
  },
  "dependencies": {
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.40.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@gdgjp/gdg-lib": "workspace:*",
    "@google/genai": "^1.43.0",
    "@react-router/cloudflare": "~7.13.0",
    "@tiptap/core": "^3.20.0",
    "@tiptap/extension-image": "^3.20.0",
    "@tiptap/extension-link": "^3.20.0",
    "@tiptap/extension-table": "^3.20.0",
    "@tiptap/extension-table-cell": "^3.20.0",
    "@tiptap/extension-table-header": "^3.20.0",
    "@tiptap/extension-table-row": "^3.20.0",
    "@tiptap/pm": "^3.20.0",
    "@tiptap/react": "^3.20.0",
    "@tiptap/starter-kit": "^3.20.0",
    "better-auth": "^1.5.2",
    "diff": "^8.0.3",
    "dompurify": "^3.3.1",
    "drizzle-orm": "^0.45.1",
    "emoji-picker-react": "^4.18.0",
    "firebase": "^12.10.0",
    "i18next": "^25.8.13",
    "isbot": "^5.1.17",
    "lib0": "^0.2.117",
    "lucide-react": "^0.577.0",
    "marked": "^17.0.3",
    "md-editor-rt": "^6.4.0",
    "mermaid": "^11.12.3",
    "nanoid": "^5.1.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-i18next": "^16.5.4",
    "react-router": "~7.13.0",
    "remix-i18next": "^7.4.2",
    "y-protocols": "^1.0.7",
    "yjs": "^13.6.30",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/puppeteer": "^1.0.6",
    "@cloudflare/vite-plugin": "^1.28.0",
    "@cloudflare/workers-types": "^4.20260316.1",
    "@playwright/test": "^1.50.0",
    "@react-router/dev": "~7.13.0",
    "@tailwindcss/vite": "^4.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/dompurify": "^3.2.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "better-sqlite3": "^12.8.0",
    "drizzle-kit": "^0.31.9",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vite-tsconfig-paths": "^5.0.0",
    "vitest": "^3.0.0",
    "wrangler": "^4.73.0"
  }
}

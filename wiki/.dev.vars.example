# Copy this file to .dev.vars and fill in real values for local development.
# Wrangler reads .dev.vars as secrets during `pnpm dev`.
# Never commit .dev.vars — it is gitignored.

# Secrets — set as production secrets with `wrangler secret put <NAME>`.
# HMAC key for the RP's signed session + OIDC transaction cookies.
# Generate with `openssl rand -base64 48`.
RP_SESSION_SECRET=
# Client secret issued by the accounts IdP for this RP.
IDP_CLIENT_SECRET=

# Override prod URLs from wrangler.toml so dev points at the local accounts IdP.
# wiki's RR7 dev server runs on a different port from accounts (5173).
APP_URL=http://localhost:5177
ACCOUNTS_URL=http://localhost:5173
IDP_URL=http://localhost:5173

# Optional — only needed for AI ingestion/translation features
GEMINI_API_KEY=

ENVIRONMENT=development

# Secrets — set as production secrets with `wrangler secret put <NAME>`.
# HMAC key for the RP's signed session + OIDC transaction cookies.
# Generate with `openssl rand -base64 48`.
RP_SESSION_SECRET=""
# Client secret issued by the accounts IdP for this RP.
IDP_CLIENT_SECRET=""

# Required for the /analytics and /dashboard pages to read Analytics Engine via the SQL API.
# Set as production secrets too: `wrangler secret put CF_ACCOUNT_ID` and `wrangler secret put CF_AE_API_TOKEN`.
# The token needs Account → Account Analytics: Read for the dataset's account.
CF_ACCOUNT_ID=""
CF_AE_API_TOKEN=""

# Override prod URLs from wrangler.toml so dev points at the local accounts IdP
# and serves short links from the same host as the dev server.
APP_URL=http://localhost:5174
ACCOUNTS_URL=http://localhost:5173
IDP_URL=http://localhost:5173
SHORT_URL_BASE=http://localhost:5174
# Custom domain provisioning (secrets in production)
VERCEL_TOKEN=""
VERCEL_PROJECT_ID=""
VERCEL_TEAM_ID=""
GATEWAY_SHARED_SECRET=""

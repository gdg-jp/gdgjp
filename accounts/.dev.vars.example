# Secrets — set as production secrets with `wrangler secret put <NAME>`.
GOOGLE_CLIENT_SECRET=""
# HMAC key for the IdP login-session cookie. Generate with e.g. `openssl rand -base64 48`.
IDP_SESSION_SECRET=""

# Per-RP client secrets (one per app registered as a trusted OIDC client; written
# into OAUTH_KV by the /admin/seed-clients route).
TINYURL_CLIENT_SECRET=""
WIKI_CLIENT_SECRET=""
IMG_CLIENT_SECRET=""
SCHEDULER_CLIENT_SECRET=""

# Override prod URLs from wrangler.toml so dev runs the IdP at localhost.
APP_URL=http://localhost:5173

# Override RP redirect URLs so OIDC callbacks resolve to the local dev servers.
# Path must match the openid-client RP factory's callback (post-PR-2: /api/auth/callback/gdgjp).
TINYURL_REDIRECT_URLS=http://localhost:5174/api/auth/callback/gdgjp
IMG_REDIRECT_URLS=http://localhost:5175/api/auth/callback/gdgjp
SCHEDULER_REDIRECT_URLS=http://localhost:5176/api/auth/callback/gdgjp
WIKI_REDIRECT_URLS=http://localhost:5177/api/auth/callback/gdgjp
